# ── Paste ONE of these as DATABASE_URL ───────────────────────────────────────

# NeonDB (serverless Postgres)
# DATABASE_URL=postgresql://neondb_owner:YOUR_PASSWORD@ep-quiet-water-a1ygyxtp-pooler.ap-southeast-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require

# Standard PostgreSQL
# DATABASE_URL=postgresql://user:password@localhost:5432/mydb

# MySQL / PlanetScale
# DATABASE_URL=mysql://user:password@localhost:3306/mydb

# SQLite (local file)
# DATABASE_URL=./dev.db
