{
  "compilerOptions": {
    /* Basic */
    "target": "ES2020",
    "module": "commonjs",
    "moduleResolution": "node",
    /* Paths */
    "rootDir": "./src",
    "outDir": "./dist",
    /* Interop */
    "esModuleInterop": true,
    "resolveJsonModule": true,
    /* Strictness */
    "strict": true,
    /* Types */
    "types": [
      "node"
    ],
    /* Performance */
    "skipLibCheck": true
  },
  "include": [
    "src"
  ],
  "exclude": [
    "node_modules"
  ]
}